NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Vercel Supabase integration may provide this instead of ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Use Supabase's pooled or direct Postgres connection string.
# Example: postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/wc26
# Vercel Supabase integration may provide POSTGRES_URL instead.
POSTGRES_URL=postgresql://postgres:password@localhost:5432/wc26

# Official tournament seed data.
FIFA_API_BASE_URL=https://api.fifa.com/api/v3
FIFA_SEASON_ID=285023

# Live scores and schedule updates.
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_TOKEN=your-football-data-token
